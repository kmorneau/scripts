<!-- Parent decoder: handles syslog-wrapped IronDoor logs -->
<decoder name="irondoor">
  <prematch>IronDoor </prematch>
</decoder>

<!-- Child: ACCESS_DENIED -->
<decoder name="irondoor_denied">
  <parent>irondoor</parent>
  <prematch offset="after_prematch">ACCESS_DENIED</prematch>
  <regex offset="after_prematch">user_id=(\w+) badge=(\w+) door=(\S+) reason=(\w+) attempt=(\d+)</regex>
  <order>user, id, door, reason, extra_data</order>
</decoder>

<!-- Child: ACCESS_GRANTED -->
<decoder name="irondoor_granted">
  <parent>irondoor</parent>
  <prematch offset="after_prematch">ACCESS_GRANTED</prematch>
  <regex offset="after_prematch">user_id=(\w+) badge=(\w+) door=(\S+) reason=(\w+)</regex>
  <order>user, id, door, reason</order>
</decoder>
